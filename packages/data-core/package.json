{
    "name": "@trade-data-manager/data-core",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./schema": "./src/schema/index.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist",
        "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo",
        "clean:all": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo node_modules",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:check": "drizzle-kit check"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.2",
        "pg": "^8.20.0",
        "dayjs": "^1.11.10",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@trade-data-manager/tsconfig": "workspace:*",
        "@types/pg": "^8.20.0",
        "typescript": "^6.0.3",
        "tsx": "^4.21.0",
        "rimraf": "^6.0.1",
        "drizzle-kit": "^0.31.10"
    }
}

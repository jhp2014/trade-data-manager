{
    "name": "@trade-data-manager/kis",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",

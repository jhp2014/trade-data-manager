        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@trade-data-manager/tsconfig": "workspace:*",
        "@types/node": "^22.10.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^2.1.9"

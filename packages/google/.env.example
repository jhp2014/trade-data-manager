# @trade-data-manager/google 가 요구하는 환경변수(이 패키지의 계약).
# 이 파일을 .env 로 복사해 채우면 패키지가 자급자족으로 로드한다.
# 소비 앱은 Google 설정을 몰라도 됨 — createOAuthClient() / createSheetsClient() 가 여기서 알아서 읽는다.
#
# 본인 Google 계정 OAuth 하나로 Drive(백업)·Sheets(복기 R/W)를 모두 커버한다.

# GCP 콘솔에서 OAuth 클라이언트(Desktop) 발급 → client id/secret
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# 아래는 비워두고 `pnpm --filter @trade-data-manager/google login` 으로 발급(브라우저 1회 동의 → 자동 기록).
# 통합 스코프(drive.file + spreadsheets)로 1회 발급하면 Drive·Sheets 둘 다 동작.
GOOGLE_OAUTH_REFRESH_TOKEN=

# ※ 전환기 폴백: 기존 루트 .env 의 GDRIVE_OAUTH_CLIENT_ID/SECRET/REFRESH_TOKEN 도 process.env 에 있으면 읽힘.
#    단 기존 토큰은 drive.file 스코프뿐이라 Sheets 도 쓰려면 위 login 으로 1회 재발급 필요.

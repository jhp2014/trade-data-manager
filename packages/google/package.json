{
    "name": "@trade-data-manager/google",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "exports": {
        "./auth": "./src/auth/index.ts",
        "./sheets": "./src/sheets/index.ts",
        "./sheets/matrix": "./src/sheets/matrix.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "login": "tsx src/auth/login-cli.ts",
        "recon:auth": "tsx recon/01-auth.ts",
        "recon:sheets": "tsx recon/02-sheets.ts",
        "clean": "rimraf dist",

# @trade-data-manager/kis 가 요구하는 환경변수(이 패키지의 계약).
# 이 파일을 .env 로 복사해 채우면 패키지가 자급자족으로 로드한다.
# 소비 앱은 KIS 설정을 몰라도 됨 — createKis() 가 여기서 알아서 읽는다.

# 자격증명 — 단일키면 아래 둘만 채우면 됨. 키마다 # 계좌번호 (만료/메모) 주석 권장.
# 키 #1 — 계좌 XXXX-XXXX
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here

# 멀티키(선택) — _2.._20 까지. KIS 유량은 계좌(앱키)당 1초당 18건이라
# 처리량을 늘리려면 다른 계좌의 앱키를 추가하면 (키 개수 × 18건/초)로 늘어난다.
# 키 #2 — 계좌 XXXX-XXXX
# KIS_APP_KEY_2=...
# KIS_APP_SECRET_2=...

# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# 고객 타입 — 개인 P / 법인 B (기본 P)
# KIS_CUST_TYPE=P

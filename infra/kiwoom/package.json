{
    "name": "@trade-data-manager/kiwoom",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./ws": "./src/ws.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rimraf dist",
        "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo",
        "clean:all": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo node_modules",
        "recon:token": "tsx recon/01-token.ts",
        "recon:daily": "tsx recon/02-daily.ts",
        "recon:minute": "tsx recon/03-minute.ts",
        "recon:rotation": "tsx recon/04-rotation.ts",
        "recon:pagination": "tsx recon/05-pagination.ts",
        "recon:condition": "tsx recon/06-condition.ts",
        "recon:stocklist": "tsx recon/07-stocklist.ts",
        "recon:dailymcap": "tsx recon/09-daily-mcap.ts",
        "recon:scan": "tsx recon/08-scan-prune.ts"
    },
    "dependencies": {
        "axios": "^1.15.1",
        "dotenv": "^16.4.5",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "@types/ws": "^8.5.13",
        "rimraf": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^2.1.9"
    }
}

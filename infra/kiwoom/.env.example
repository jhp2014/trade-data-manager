# @trade-data-manager/kiwoom 가 요구하는 환경변수(이 패키지의 계약).
# 이 파일을 .env 로 복사해 채우면 패키지가 자급자족으로 로드한다.
# 소비 앱은 키움 설정을 몰라도 됨 — createKiwoom() 이 여기서 알아서 읽는다.

# 자격증명 — 단일키면 아래 둘만 채우면 됨. 키마다 # 계좌번호 (만료일) 주석 권장.
# 키 #1 — 계좌 XXXX-XXXX (만료 YYYY-MM-DD)
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_SECRET_KEY=your_secret_key_here

# 멀티키(선택) — _2.._20 까지. 넣으면 라운드로빈으로 (키 개수 × 5건/초)로 처리량 증가.
# 키 #2 — 계좌 XXXX-XXXX (만료 YYYY-MM-DD)
# KIWOOM_APP_KEY_2=...
# KIWOOM_SECRET_KEY_2=...

# 키 #3 — 계좌 XXXX-XXXX (만료 YYYY-MM-DD)
# KIWOOM_APP_KEY_3=...
# KIWOOM_SECRET_KEY_3=...

KIWOOM_BASE_URL=https://api.kiwoom.com

# WebSocket(실시간/조건검색) URL — WS 쓸 때만. 실전: api.kiwoom.com / 모의: mockapi.kiwoom.com
KIWOOM_WS_URL=wss://api.kiwoom.com:10000/api/dostk/websocket

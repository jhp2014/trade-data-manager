{
    "name": "@trade-data-manager/telegram",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist",
        "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo",
        "clean:all": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo node_modules",
        "recon:login": "tsx recon/01-login.ts",
        "recon:dialogs": "tsx recon/02-dialogs.ts",
        "recon:search": "tsx recon/03-search.ts"
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "telegram": "^2.26.22"
    },
    "devDependencies": {
        "@trade-data-manager/tsconfig": "workspace:*",
        "@types/node": "^22.10.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    }
}

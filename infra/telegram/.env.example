# @trade-data-manager/telegram 가 요구하는 환경변수(이 패키지의 계약).
# 이 파일을 .env 로 복사해 채운다. .env 는 gitignore — 절대 커밋 금지.
#
# ── 앱 등록 정보(계정 비번 아님) ──────────────────────────────
# https://my.telegram.org → API development tools 에서 1회 발급.
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# ── 내 계정 ───────────────────────────────────────────────
# 국가코드 포함. 예: +8210xxxxxxxx
TELEGRAM_PHONE=+8210xxxxxxxx
# 2단계 인증(비밀번호)을 켜놨을 때만. 안 켰으면 비워둔다.
TELEGRAM_2FA_PASSWORD=

# ── 세션(로그인 결과) ─────────────────────────────────────
# 처음엔 비워둔다. recon:login 을 1회 실행하면 콘솔에 세션 문자열이 찍히고,
# 그걸 여기 붙여넣으면 이후로는 코드 입력 없이 무인 접속된다.
# ⚠️ 이 문자열은 내 계정 풀권한이다 — api_hash 보다도 민감하게 다룰 것.
TELEGRAM_SESSION=

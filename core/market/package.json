{
    "name": "@trade-data-manager/market",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./domain": "./src/domain/index.ts",
        "./port": "./src/application/port/index.ts",
        "./internal": "./src/internal.ts"
    },
    "imports": {
        "#domain": "./src/domain/index.ts",
        "#port/collect": "./src/application/port/collect/index.ts",
        "#port/query": "./src/application/port/query/index.ts"

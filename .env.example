# ── 키움 API ──────────────────────────────────────────────────────────────────
# apps/batch 전용
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_SECRET_KEY=your_secret_key_here
KIWOOM_BASE_URL=https://api.kiwoom.com

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trade-data-manager

# ── batch ──────────────────────────────────────────────────────────────────────
# CSV 입력 폴더 경로 (절대 경로 권장)
CSV_FOLDER=/path/to/batch-csv-input

# ── review-ingest (Google Sheet export, Phase 4) ───────────────────────────────
# 내보낼 스프레드시트 ID (URL의 /d/ 와 /edit 사이 토큰)
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# 내보낼 탭 이름 (기본: review)
GOOGLE_SHEETS_TAB=review
# 인증 방식 A) 서비스계정 JSON 키 파일 경로 (프로젝트 루트에 두고 gitignore 권장)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# 인증 방식 B) JSON을 풀어 직접 기입 (A가 없을 때 사용)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@yyy.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ※ 시트를 위 서비스계정 이메일에 "편집자"로 공유해야 export(쓰기) 가능
REVIEW_APP_BASE_URL=http://localhost:3200
CHART_REVIEW_TARGET_DIR=

# ── chart-capture ─────────────────────────────────────────────────────────────
# CSV 입력 디렉터리 (절대 경로 권장)
CAPTURE_INPUT_DIR=/path/to/capture-input

# PNG 출력 디렉터리 (절대 경로 권장)
CAPTURE_OUTPUT_DIR=/path/to/capture-output

# 브라우저 뷰포트 크기 (기본: 2560x1440)
# CAPTURE_VIEWPORT_W=2560
# CAPTURE_VIEWPORT_H=1440

# 캡처 영역 크기 (기본: 2400x1400)
# CAPTURE_BOX_W=2400
# CAPTURE_BOX_H=1400

# 일봉 조회 거래일 수 (기본: 300)
# CAPTURE_LOOKBACK_DAYS=300

# 디바이스 픽셀 비율 (기본: 1)
# CAPTURE_DPR=1

# 동시 캡처 수 (기본: 1)
# CAPTURE_CONCURRENCY=1

# Next.js 서버 포트 (기본: 3939)
# CAPTURE_NEXT_PORT=3939

# Playwright 타임아웃 (단위 ms)
# CAPTURE_NAV_TIMEOUT_MS=60000
# CAPTURE_READY_TIMEOUT_MS=30000

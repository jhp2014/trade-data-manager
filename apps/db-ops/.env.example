# @trade-data-manager/db-ops 자체 .env — DB 물리 운영 도구 고유 설정만.
# DB 접속은 @infra/persistence(.env), Google OAuth 는 @infra/google(.env)가 자급 → 여긴 백업 고유 설정만.

# pg_dump 전체 백업 생성·검증 + 로컬 1차 보관
BACKUP_LOCAL_DIR=C:/path/to/db-backup-local

# PostgreSQL 클라이언트 도구 경로 (pg_dump / pg_restore / createdb / dropdb)
PG_BIN_DIR=C:/Program Files/PostgreSQL/17/bin

# Google Drive 백업 대상 폴더 ID (Drive 폴더 URL 의 /folders/ 뒤 토큰)
GDRIVE_BACKUP_FOLDER_ID=<drive-folder-id>

{
    "name": "@trade-data-manager/feature-processor",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist",
        "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo",
        "clean:all": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo node_modules"
    },
    "dependencies": {
        "@trade-data-manager/data-core": "workspace:*",
        "commander": "^12.1.0",
        "dayjs": "^1.11.10",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@trade-data-manager/tsconfig": "workspace:*",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.20.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.19.0",
        "typescript": "^6.0.3"
    }
}

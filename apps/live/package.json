{
    "name": "@trade-data-manager/live",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "tsx src/main.ts",
        "dev": "tsx watch src/main.ts",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rimraf dist",
        "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@nestjs/common": "^10.4.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@trade-data-manager/kiwoom": "workspace:*",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^2.1.9"
    }
}

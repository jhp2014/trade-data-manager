# apps/live — 실시간 모니터 백엔드 설정
# 이 파일을 .env 로 복사해서 값을 채워. (.env 는 git 에 안 올라감)
#   PowerShell: Copy-Item .env.example .env

# 스캔할 조건식 이름(부팅 기본값) — 영웅문 HTS 에 서버저장된 조건식 이름과 정확히 일치해야 함.
# 진실 소스는 엔진설정 파일(LIVE_ENGINE_CONFIG, 워크벤치 설정>조건검색에서 선택·영속)이고
# env 는 파일에 기록이 없을 때만 쓰인다. 미선택이어도 엔진은 시작(스캔 없이 watchlist 폴링만).
LIVE_CONDITION_NAME=

# 엔진 설정(조건검색 선택) JSON 파일 경로(기본 data/live-engine.json, cwd=apps/live 기준).
# LIVE_ENGINE_CONFIG=data/live-engine.json

# HTTP 포트(기본 3002). workbench vite 프록시(/live)가 이 포트로 향한다.
LIVE_PORT=3002

# 바인드 호스트(기본 0.0.0.0). 호스팅 시엔 Tailscale IP(100.x.x.x)로 지정해 공인 IP 에
# 포트를 열지 않는다(공개 노출 금지). 로컬 개발은 비워두면 0.0.0.0.
# LIVE_HOST=100.x.x.x

# 폴링/스캔 주기 ms(기본 5000).
LIVE_POLL_MS=5000

# 알람 설정(watchlist+룰) JSON 파일 경로(기본 data/live-alerts.json, cwd=apps/live 기준).
# LIVE_ALERT_CONFIG=data/live-alerts.json

# 알람 텔레그램 전달 — 전송로 선택(미설정/불충분이면 서버 로그로만).
#  · bot(기본): Bot API. LIVE_TELEGRAM_BOT_TOKEN + LIVE_TELEGRAM_CHAT_ID 필요.
#    봇 생성: @BotFather → /newbot → 토큰. chat id: 채널이면 봇을 관리자로 추가 후 -100… id.
#    ⚠️ 로컬 망(KT 추정)이 api.telegram.org IP 를 차단해 로컬 불통 — 호스팅(OCI)용.
#  · user: MTProto(내 계정, infra/telegram/.env 세션 자급). 로컬 대체 전송로.
#    게시 대상은 LIVE_TELEGRAM_PEER(@유저명 또는 -100id) — 없으면 CHAT_ID 재사용.
#    ⚠️ 내 계정 발신이라 내 폰엔 푸시가 안 옴(채널 기록·타 구독자 알림용).
LIVE_TELEGRAM_TRANSPORT=bot
LIVE_TELEGRAM_BOT_TOKEN=
LIVE_TELEGRAM_CHAT_ID=
# LIVE_TELEGRAM_PEER=

# ── 알람 신뢰 축(하트비트·데드맨) ─────────────────────────────────
# 외부 데드맨 핑 URL(healthchecks.io 체크, Period 5min/Grace 5min 권장). 설정 시 60초마다 핑.
# 게이트 = 장중(알림 창)엔 완전 건강(틱 신선∧WS live∧전송로 정상)일 때만 / 장외엔 프로세스 생존이면 핑.
# 핑이 끊기면 healthchecks 가 메일/텔레그램으로 알림 — 서버 전멸·크래시루프·봇토큰 죽음까지 부재로 감지.
# LIVE_HEALTHCHECK_URL=https://hc-ping.com/<uuid>

# 이상/회복 알림·하트비트가 동작하는 창(평일 KST). 기본 08:00-15:40 — 키움 심야 점검(WS 끊김)에 안 울리게.
# LIVE_ALERT_WINDOW=08:00-15:40

# 아침 하트비트("✅ 정상 — 조건 N개")·장마감 요약 on/off. 기본 on, 끄려면 0.
# LIVE_HEARTBEAT=1

# 참고: 키움 API 크레덴셜(KIWOOM_APP_KEY 등)은 여기가 아니라 infra/kiwoom/.env 에 있음.

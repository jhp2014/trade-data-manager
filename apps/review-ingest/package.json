{
  "name": "@trade-data-manager/review-ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "clean:cache": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo",
    "clean:all": "rimraf dist node_modules/.cache .turbo tsconfig.tsbuildinfo node_modules"
  },
  "dependencies": {
    "@trade-data-manager/data-core": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^144.0.0",
    "papaparse": "^5.4.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@trade-data-manager/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.20.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  }
}

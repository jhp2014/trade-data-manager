{
    "extends": "@trade-data-manager/tsconfig/base.json",
    "compilerOptions": {
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "jsx": "preserve",
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "strict": true,
        "noEmit": true,
        "allowJs": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
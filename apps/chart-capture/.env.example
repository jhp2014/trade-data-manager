# ── 필수 ────────────────────────────────────────────────────
# PostgreSQL 연결 문자열
DATABASE_URL=postgresql://user:password@localhost:5432/trade_data

# CSV 입력 디렉토리 (절대 경로 권장)
CAPTURE_INPUT_DIR=/path/to/input

# PNG 출력 디렉토리 (절대 경로 권장)
CAPTURE_OUTPUT_DIR=/path/to/output

# ── 선택 (기본값 있음) ───────────────────────────────────────
# 일봉 조회 거래일 수 (기본: 300)
# CAPTURE_LOOKBACK_DAYS=300

# 브라우저 뷰포트 크기 (기본: 2560x1440)
# CAPTURE_VIEWPORT_W=2560
# CAPTURE_VIEWPORT_H=1440

# 디바이스 픽셀 비율 (기본: 1 / DPR 2 원할 시 2로 설정)
# CAPTURE_DPR=1

# 캡처 영역 크기 (기본: 2400x1400)
# CAPTURE_BOX_W=2400
# CAPTURE_BOX_H=1400

# 동시 캡처 수 (기본: 1)
# CAPTURE_CONCURRENCY=1

# Next.js 서버 포트 (기본: 3939)
# CAPTURE_NEXT_PORT=3939
